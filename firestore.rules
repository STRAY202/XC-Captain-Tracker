rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All authenticated users (including anonymous) can read and write.
    // This covers all team members after they pass the team code gate in the UI.
    // The team code and admin code provide application-level access control.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
